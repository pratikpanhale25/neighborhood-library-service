# Secret for signing the session cookie (use a long random string in dev/prod).
AUTH_SECRET=change-me-to-a-long-random-string

# Browser and server fetch target for the FastAPI REST API (see docker-compose).
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# Optional: gRPC for advanced clients (fines, etc.) — Next.js server-side only if you use grpc-client.
LIBRARY_GRPC_HOST=127.0.0.1
LIBRARY_GRPC_PORT=50051
