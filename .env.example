# Copy to `.env` for local `library-server`.

# SQLAlchemy (psycopg2 driver). Use port 5433 when using docker-compose postgres published port.
DATABASE_URL=postgresql+psycopg2://library:library@127.0.0.1:5433/neighborhood_library

GRPC_HOST=0.0.0.0
GRPC_PORT=50051

HTTP_HOST=0.0.0.0
HTTP_PORT=8000

DEFAULT_LOAN_PERIOD_DAYS=14
FINE_CENTS_PER_DAY=50
FINE_GRACE_DAYS=0
FINE_CURRENCY_CODE=USD
